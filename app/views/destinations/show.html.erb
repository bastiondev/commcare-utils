<div class="d-flex justify-content-between align-items-center mb-4">
      <h1><%= @destination.name %></h1>
      <div>
        <%= link_to 'Edit', edit_destination_path(@destination), class: 'btn btn-outline-primary' %>
        <%= link_to 'Delete', destination_path(@destination), method: :delete, data: { turbo_confirm: 'Are you sure you wish to delete this destination?' }, class: 'btn btn-outline-danger' %>
        <%= link_to 'Back', destinations_path, class: 'btn btn-outline-secondary' %>
      </div>
    </div>

    <div class="card mb-4">
      <div class="card-body">
        <div class="row mb-3">
          <div class="col-md-6">
            <h6 class="text-muted">CommCare Project Name</h6>
            <p><%= @destination.project_name %></p>
          </div>
          <div class="col-md-6">
            <h6 class="text-muted">CommCare Username</h6>
            <p><%= @destination.commcare_username %></p>
          </div>
        </div>
        <div class="row mb-3">
          <div class="col-md-12">
            <h6 class="text-muted">Database URL</h6>
            <p><code><%= @destination.database_url_for_display %></code></p>
          </div>
        </div>
      </div>
    </div>

    <div class="card mt-5">
      <div class="card-header">
        <h5 class="mb-0">API Tokens</h5>
      </div>
      <div class="card-body">
        <div class="alert alert-secondary mb-3">
          <strong>How to use:</strong> Configure CommCare data forwarding with the following URL and authorization header:
          <br><code><%= request.base_url %>/api/forwarding</code>
          <br>Authorization: <code>Bearer &lt;token&gt;</code> or <code>&lt;token&gt;</code>
        </div>

        <% if @destination.destination_tokens.any? %>
          <div class="table-responsive mb-3">
            <table class="table table-sm table-striped table-bordered">
              <thead>
                <tr>
                  <th>Token</th>
                  <th>Created</th>
                  <th>Last Accessed</th>
                  <th>Action</th>
                </tr>
              </thead>
              <tbody>
                <% @destination.destination_tokens.each do |token| %>
                  <tr>
                    <td><code><%= token.token %></code></td>
                    <td><%= token.created_at.strftime('%Y-%m-%d %H:%M:%S') %></td>
                    <td><%= token.last_accessed_at&.strftime('%Y-%m-%d %H:%M:%S') || 'Never' %></td>
                    <td style="white-space: nowrap;">
                      <%= button_to 'Delete', delete_token_destination_path(@destination, token_id: token.id), method: :post, data: { turbo_confirm: 'Are you sure you wish to delete this token?' }, class: 'btn btn-sm btn-outline-danger' %>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% else %>
          <p class="text-muted">No tokens yet.</p>
        <% end %>

        <div>
          <%= button_to 'Create Token', create_token_destination_path(@destination), method: :post, class: 'btn btn-outline-primary btn-sm' %>
        </div>
      </div>
    </div>

    <div class="card mt-5">
      <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Destination Sources</h5>
        <%= link_to 'Add Source', new_destination_destination_source_path(@destination), class: 'btn btn-outline-primary btn-sm' %>
      </div>
      <div class="card-body">
        <% if @destination.destination_sources.any? %>
          <div class="table-responsive">
            <table class="table table-sm table-striped table-bordered">
              <thead>
                <tr>
                  <th>Name</th>
                  <th>Case Type</th>
                  <th>Key Column</th>
                  <th>Table Name</th>
                  <th>Sensitive Fields</th>
                  <th>Daily Sync?</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody>
                <% @destination.destination_sources.each do |source| %>
                  <tr>
                    <td><%= source.name %></td>
                    <td><%= source.case_type %></td>
                    <td><%= source.key_column %></td>
                    <td><code><%= source.table_name %></code></td>
                    <td><small><%= source.sensitive_fields %></small></td>
                    <td><%= source.scheduled_sync ? 'Yes' : 'No' %></td>
                    <td style="white-space: nowrap;">
                      <%= button_to 'Sync', sync_destination_destination_source_path(@destination, source), method: :post, data: { turbo_confirm: 'Are you sure you wish to enqueue a sync for this destination source?' }, class: 'btn btn-sm btn-outline-success', form: { style: 'display: inline-block;' } %>
                      <%= link_to 'Edit', edit_destination_destination_source_path(@destination, source), class: 'btn btn-sm btn-outline-primary' %>
                      <%= link_to 'Delete', destination_destination_source_path(@destination, source), method: :delete, data: { turbo_confirm: 'Are you sure you wish to delete this source?' }, class: 'btn btn-sm btn-outline-danger' %>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% else %>
          <div class="alert alert-info">
            No destination sources configured.
          </div>
        <% end %>
      </div>
    </div>

    <div class="card mt-5">
      <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Form Mappings</h5>
        <%= link_to 'Add Form Mapping', new_destination_form_mapping_path(@destination), class: 'btn btn-outline-primary btn-sm' %>
      </div>
      <div class="card-body">
        <% if @destination.form_mappings.any? %>
          <% @destination.form_mappings.includes(:form_mapping_tables).each do |mapping| %>
            <div class="card mb-3">
              <div class="card-header d-flex justify-content-between align-items-center bg-light">
                <div>
                  <strong><%= mapping.name %></strong>
                  <br><small class="text-muted">Form names: <%= mapping.form_names_array.map { |fn| "\"#{fn}\"" }.join(', ') %></small>
                </div>
                <div style="white-space: nowrap;">
                  <%= link_to 'Add Table', new_destination_form_mapping_form_mapping_table_path(@destination, mapping), class: 'btn btn-sm btn-outline-success' %>
                  <%= link_to 'Edit', edit_destination_form_mapping_path(@destination, mapping), class: 'btn btn-sm btn-outline-primary' %>
                  <%= link_to 'Delete', destination_form_mapping_path(@destination, mapping), method: :delete, data: { turbo_confirm: 'Are you sure you wish to delete this form mapping and all its table mappings?' }, class: 'btn btn-sm btn-outline-danger' %>
                </div>
              </div>
              <div class="card-body p-0">
                <% if mapping.form_mapping_tables.any? %>
                  <div class="table-responsive">
                    <table class="table table-sm table-striped table-bordered mb-0">
                      <thead>
                        <tr>
                          <th>Table Name</th>
                          <th>JSON Path</th>
                          <th>Sensitive Fields</th>
                          <th>Actions</th>
                        </tr>
                      </thead>
                      <tbody>
                        <% mapping.form_mapping_tables.each do |fmt| %>
                          <tr>
                            <td><code><%= fmt.table_name %></code></td>
                            <td><code><%= fmt.json_path %></code></td>
                            <td><small><%= fmt.sensitive_fields %></small></td>
                            <td style="white-space: nowrap;">
                              <%= link_to 'Edit', edit_destination_form_mapping_form_mapping_table_path(@destination, mapping, fmt), class: 'btn btn-sm btn-outline-primary' %>
                              <%= link_to 'Delete', destination_form_mapping_form_mapping_table_path(@destination, mapping, fmt), method: :delete, data: { turbo_confirm: 'Are you sure?' }, class: 'btn btn-sm btn-outline-danger' %>
                            </td>
                          </tr>
                        <% end %>
                      </tbody>
                    </table>
                  </div>
                <% else %>
                  <div class="p-3">
                    <p class="text-muted mb-0">No table mappings configured. Add a table mapping to define where form data should be written.</p>
                  </div>
                <% end %>
              </div>
            </div>
          <% end %>
        <% else %>
          <div class="alert alert-info">
            No form mappings configured. Form mappings define how incoming CommCare form submissions are flattened into database tables.
          </div>
        <% end %>
      </div>
    </div>
